<?xml version="1.0" encoding="utf-8"?>
<dev.oneuiproject.oneui.layout.ToolbarLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?roundedCornerColor"
    app:expanded="false"
    app:expandable="false"
    app:title="@string/settings_theme_title">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:colorBackground"
                android:orientation="vertical"
                android:padding="18dp"
                app:roundedCorners="all">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_theme_picker_title"
                    android:textAppearance="?android:attr/textAppearanceLarge"
                    android:textColor="?android:textColorPrimary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_theme_picker_summary"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="?android:textColorSecondary" />
            </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

            <LinearLayout
                android:id="@+id/card_theme_system"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_surface_card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="128dp"
                android:orientation="horizontal"
                android:padding="18dp">

                <ImageView
                    android:layout_width="124dp"
                    android:layout_height="88dp"
                    android:contentDescription="@null"
                    android:scaleType="fitXY"
                    android:src="@drawable/preview_theme_system" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/theme_mode_system"
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:textColor="?android:textColorPrimary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/theme_mode_system_summary"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="?android:textColorSecondary" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/icon_theme_system_selected"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_check_circle"
                    android:tint="?attr/colorPrimary"
                    android:visibility="invisible" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_theme_light"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_surface_card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="128dp"
                android:orientation="horizontal"
                android:padding="18dp">

                <ImageView
                    android:layout_width="124dp"
                    android:layout_height="88dp"
                    android:contentDescription="@null"
                    android:scaleType="fitXY"
                    android:src="@drawable/preview_theme_light" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/theme_mode_light"
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:textColor="?android:textColorPrimary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/theme_mode_light_summary"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="?android:textColorSecondary" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/icon_theme_light_selected"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_check_circle"
                    android:tint="?attr/colorPrimary"
                    android:visibility="invisible" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_theme_dark"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_surface_card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:minHeight="128dp"
                android:orientation="horizontal"
                android:padding="18dp">

                <ImageView
                    android:layout_width="124dp"
                    android:layout_height="88dp"
                    android:contentDescription="@null"
                    android:scaleType="fitXY"
                    android:src="@drawable/preview_theme_dark" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/theme_mode_dark"
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:textColor="?android:textColorPrimary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/theme_mode_dark_summary"
                        android:textAppearance="?android:attr/textAppearanceSmall"
                        android:textColor="?android:textColorSecondary" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/icon_theme_dark_selected"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_check_circle"
                    android:tint="?attr/colorPrimary"
                    android:visibility="invisible" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</dev.oneuiproject.oneui.layout.ToolbarLayout>
