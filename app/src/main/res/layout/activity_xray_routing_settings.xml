<?xml version="1.0" encoding="utf-8"?>
<dev.oneuiproject.oneui.layout.ToolbarLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?roundedCornerColor"
    app:expanded="false"
    app:expandable="false"
    app:title="@string/xray_routing_settings_title">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingTop="10dp">

            <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:colorBackground"
                android:orientation="vertical"
                android:padding="18dp"
                app:roundedCorners="all">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/xray_routing_geo_files_title"
                    android:textAppearance="?android:attr/textAppearanceLarge"
                    android:textColor="?android:textColorPrimary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/xray_routing_geo_files_summary"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:textColor="?android:textColorSecondary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/card_geoip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_surface_card"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/text_geoip_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/xray_routing_geoip_title"
                                    android:textAppearance="?android:attr/textAppearanceMedium"
                                    android:textColor="?android:textColorPrimary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/text_geoip_status"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:textAppearance="?android:attr/textAppearanceSmall"
                                    android:textColor="?android:textColorSecondary" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/text_geoip_badge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_profile_ping_bad"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp"
                                android:textAppearance="?android:attr/textAppearanceSmall"
                                android:textColor="@android:color/white"
                                android:textStyle="bold" />

                            <ProgressBar
                                android:id="@+id/progress_geoip_download"
                                style="?android:attr/progressBarStyleSmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:visibility="gone" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/text_geoip_source"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:ellipsize="middle"
                            android:maxLines="2"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="?android:textColorSecondary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/button_geoip_edit_url"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/xray_routing_edit_url" />

                            <Button
                                android:id="@+id/button_geoip_download"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="@string/xray_routing_download_geo" />

                            <Button
                                android:id="@+id/button_geoip_import"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="@string/xray_routing_import_geo" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/card_geosite"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_surface_card"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/text_geosite_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/xray_routing_geosite_title"
                                    android:textAppearance="?android:attr/textAppearanceMedium"
                                    android:textColor="?android:textColorPrimary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/text_geosite_status"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:textAppearance="?android:attr/textAppearanceSmall"
                                    android:textColor="?android:textColorSecondary" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/text_geosite_badge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_profile_ping_bad"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp"
                                android:textAppearance="?android:attr/textAppearanceSmall"
                                android:textColor="@android:color/white"
                                android:textStyle="bold" />

                            <ProgressBar
                                android:id="@+id/progress_geosite_download"
                                style="?android:attr/progressBarStyleSmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:visibility="gone" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/text_geosite_source"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:ellipsize="middle"
                            android:maxLines="2"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="?android:textColorSecondary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/button_geosite_edit_url"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/xray_routing_edit_url" />

                            <Button
                                android:id="@+id/button_geosite_download"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="@string/xray_routing_download_geo" />

                            <Button
                                android:id="@+id/button_geosite_import"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="@string/xray_routing_import_geo" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </dev.oneuiproject.oneui.widget.RoundedLinearLayout>

            <dev.oneuiproject.oneui.widget.RoundedLinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="?android:colorBackground"
                android:orientation="vertical"
                app:roundedCorners="all">

                <LinearLayout
                    android:id="@+id/entry_rules"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:selectableItemBackground"
                    android:gravity="center_vertical"
                    android:minHeight="72dp"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/xray_routing_rules_title"
                            android:textAppearance="?android:attr/textAppearanceLarge"
                            android:textColor="?android:textColorPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/text_rules_entry_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/xray_routing_rules_entry_summary"
                            android:textAppearance="?android:attr/textAppearanceSmall"
                            android:textColor="?android:textColorSecondary" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </dev.oneuiproject.oneui.widget.RoundedLinearLayout>
        </LinearLayout>
    </ScrollView>

</dev.oneuiproject.oneui.layout.ToolbarLayout>
